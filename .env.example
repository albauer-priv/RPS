# Core LLM runtime (global only)
RPS_LLM_API_KEY=
RPS_LLM_BASE_URL=
RPS_LLM_ORG_ID=
RPS_LLM_PROJECT_ID=
RPS_LLM_MODEL=gpt-5.4-mini
RPS_LLM_TEMPERATURE=0.2
RPS_LLM_REASONING_EFFORT=medium
RPS_LLM_REASONING_SUMMARY=auto
RPS_LLM_MAX_COMPLETION_TOKENS=8000

# Intervals.icu data pipeline
ATHLETE_ID=
API_KEY=
BASE_URL=https://intervals.icu/api/v1

# Workspace and local paths
ATHLETE_WORKSPACE_ROOT=runtime/athletes
# SCHEMA_DIR=specs/schemas
# PROMPTS_DIR=prompts

# Optional operations / logging
RPS_LOG_LEVEL=INFO
RPS_LOG_CONSOLE=WARNING
RPS_LOG_FILE=INFO
RPS_LOG_UI=INFO
RPS_LOG_ROTATE_MB=50
RPS_LOG_RETENTION_DAYS=7
RPS_RUN_RETENTION_DAYS=7
RPS_INTERVALS_MAX_AGE_HOURS=2
RPS_HISTORICAL_YEARS=3
RPS_DISABLE_INTERVALS_REFRESH=0
RPS_COACH_PRELOAD_ARTIFACTS=1
RPS_COACH_PRELOAD_MAX_CHARS=12000
