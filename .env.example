OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=
# Optional per-agent model overrides
OPENAI_MODEL_MACRO_PLANNER=gpt-4.1
OPENAI_MODEL_MESO_ARCHITECT=gpt-4.1
OPENAI_MODEL_MICRO_PLANNER=gpt-4.1-mini
OPENAI_MODEL_WORKOUT_BUILDER=gpt-5.1-codex-mini
OPENAI_MODEL_PERFORMANCE_ANALYSIS=gpt-4.1
# Optional per-agent temperature overrides
OPENAI_TEMPERATURE_MACRO_PLANNER=0.2
OPENAI_TEMPERATURE_MESO_ARCHITECT=0.2
OPENAI_TEMPERATURE_MICRO_PLANNER=0.2
OPENAI_TEMPERATURE_WORKOUT_BUILDER=0.2
OPENAI_TEMPERATURE_PERFORMANCE_ANALYSIS=0.3

# Optional reasoning settings (reasoning-capable models only)
OPENAI_REASONING_EFFORT=medium
OPENAI_REASONING_SUMMARY=auto

# Streaming output (Responses API)
# OPENAI_STREAM=1 enables streaming; set to 0 to disable.
OPENAI_STREAM=1
# OPENAI_STREAM_REASONING=full streams full reasoning if the model emits it (summary is safer).
# Options: full | summary | none
OPENAI_STREAM_REASONING=full
# OPENAI_STREAM_TEXT=1 streams normal output text.
OPENAI_STREAM_TEXT=1
# OPENAI_STREAM_USAGE=1 prints total token usage on completion.
OPENAI_STREAM_USAGE=1
# OPENAI_STREAM_LOG_REASONING=1 logs reasoning to the logger on completion.
OPENAI_STREAM_LOG_REASONING=1
# OPENAI_STREAM_ITALICS=1 renders streamed reasoning in italics (if terminal supports it).
OPENAI_STREAM_ITALICS=1

# Logging (default level for CLI + scripts)
APP_LOG_LEVEL=INFO

# Intervals.icu data pipeline
ATHLETE_ID=
API_KEY=
BASE_URL=https://intervals.icu/api/v1

OPENAI_VECTORSTORE_ALL_AGENTS_ID=

ATHLETE_WORKSPACE_ROOT=var/athletes
SCHEMA_DIR=schemas
PROMPTS_DIR=prompts
VECTORSTORE_STATE_PATH=.cache/vectorstores_state.json
