# LLM runtime (LiteLLM)
RPS_LLM_API_KEY=
RPS_LLM_ORG_ID=
RPS_LLM_PROJECT_ID=
RPS_LLM_BASE_URL=
RPS_LLM_MODEL=gpt-4.1
RPS_LLM_TEMPERATURE=
RPS_LLM_EMBEDDING_MODEL=text-embedding-3-small
RPS_LLM_EMBEDDING_BATCH_SIZE=32
RPS_LLM_VECTORSTORE_PATH=.cache/qdrant

# Optional reasoning settings (reasoning-capable models only)
RPS_LLM_REASONING_EFFORT=medium
RPS_LLM_REASONING_SUMMARY=auto

# Agent overrides (grouped by agent)
# Season Planner
RPS_LLM_MODEL_SEASON_PLANNER=gpt-4.1
RPS_LLM_TEMPERATURE_SEASON_PLANNER=0.2
RPS_LLM_REASONING_EFFORT_SEASON_PLANNER=
RPS_LLM_REASONING_SUMMARY_SEASON_PLANNER=
RPS_LLM_API_KEY_SEASON_PLANNER=
RPS_LLM_BASE_URL_SEASON_PLANNER=

# Phase Architect
RPS_LLM_MODEL_PHASE_ARCHITECT=gpt-4.1
RPS_LLM_TEMPERATURE_PHASE_ARCHITECT=0.2
RPS_LLM_REASONING_EFFORT_PHASE_ARCHITECT=
RPS_LLM_REASONING_SUMMARY_PHASE_ARCHITECT=
RPS_LLM_API_KEY_PHASE_ARCHITECT=
RPS_LLM_BASE_URL_PHASE_ARCHITECT=

# Week Planner
RPS_LLM_MODEL_WEEK_PLANNER=gpt-4.1-mini
RPS_LLM_TEMPERATURE_WEEK_PLANNER=0.2
RPS_LLM_REASONING_EFFORT_WEEK_PLANNER=
RPS_LLM_REASONING_SUMMARY_WEEK_PLANNER=
RPS_LLM_API_KEY_WEEK_PLANNER=
RPS_LLM_BASE_URL_WEEK_PLANNER=

# Workout Builder
RPS_LLM_MODEL_WORKOUT_BUILDER=gpt-5.1-codex-mini
RPS_LLM_TEMPERATURE_WORKOUT_BUILDER=0.2
RPS_LLM_REASONING_EFFORT_WORKOUT_BUILDER=
RPS_LLM_REASONING_SUMMARY_WORKOUT_BUILDER=
RPS_LLM_API_KEY_WORKOUT_BUILDER=
RPS_LLM_BASE_URL_WORKOUT_BUILDER=

# Performance Analysis
RPS_LLM_MODEL_PERFORMANCE_ANALYSIS=gpt-4.1
RPS_LLM_TEMPERATURE_PERFORMANCE_ANALYSIS=0.3
RPS_LLM_REASONING_EFFORT_PERFORMANCE_ANALYSIS=
RPS_LLM_REASONING_SUMMARY_PERFORMANCE_ANALYSIS=
RPS_LLM_API_KEY_PERFORMANCE_ANALYSIS=
RPS_LLM_BASE_URL_PERFORMANCE_ANALYSIS=

# Streaming output (Responses API)
# RPS_LLM_STREAM=1 enables streaming; set to 0 to disable.
RPS_LLM_STREAM=1
# RPS_LLM_STREAM_TEXT=1 streams normal output text.
RPS_LLM_STREAM_TEXT=1
# RPS_LLM_STREAM_USAGE=1 prints total token usage on completion.
RPS_LLM_STREAM_USAGE=1

# LLM debug + reasoning logs
# RPS_LLM_DEBUG=1 enables debug logging for LLM tools/stream events.
RPS_LLM_DEBUG=0
# RPS_LLM_REASONING_LOG controls reasoning output (off|summary|full).
RPS_LLM_REASONING_LOG=off
# Optional: reasoning log file (only used when reasoning log is enabled).
RPS_LLM_REASONING_LOG_FILE=var/athletes/<athlete_id>/logs/reasoning_chunks.log

# Logging (global defaults; console/file/UI can override)
RPS_LOG_LEVEL=INFO
# Console log level; set to OFF to disable console logging.
RPS_LOG_CONSOLE=WARNING
# File log level for rps.log.
RPS_LOG_FILE=DEBUG
# UI system log level (Streamlit system log panel).
RPS_LOG_UI=INFO

# Intervals.icu data pipeline
ATHLETE_ID=
API_KEY=
BASE_URL=https://intervals.icu/api/v1

ATHLETE_WORKSPACE_ROOT=var/athletes
SCHEMA_DIR=schemas
PROMPTS_DIR=prompts
VECTORSTORE_STATE_PATH=.cache/vectorstores_state.json
