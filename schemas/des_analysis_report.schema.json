{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "des_analysis_report.schema.json",
  "title": "DESAnalysisReport",
  "type": "object",
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red",
        "inconclusive"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "des_analysis_report_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_meta",
        "kpi_summary",
        "weekly_analysis",
        "trend_analysis",
        "recommendation",
        "narrative_report"
      ],
      "properties": {
        "summary_meta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "year",
            "iso_week",
            "run_id"
          ],
          "properties": {
            "year": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100
            },
            "iso_week": {
              "type": "integer",
              "minimum": 1,
              "maximum": 53
            },
            "run_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "kpi_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "durability",
            "fatigue_resistance",
            "fueling_stability"
          ],
          "properties": {
            "durability": {
              "$ref": "#/$defs/kpi_status_entry"
            },
            "fatigue_resistance": {
              "$ref": "#/$defs/kpi_status_entry"
            },
            "fueling_stability": {
              "$ref": "#/$defs/kpi_status_entry"
            }
          }
        },
        "weekly_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context",
            "signals",
            "interpretation"
          ],
          "properties": {
            "context": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "phase_week",
                "phase_focus"
              ],
              "properties": {
                "phase_week": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4
                },
                "phase_focus": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "observation",
                  "confidence"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "observation": {
                    "type": "string",
                    "minLength": 1
                  },
                  "confidence": {
                    "$ref": "#/$defs/confidence"
                  }
                }
              }
            },
            "interpretation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "summary"
              ],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "trend_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "horizon_weeks",
            "observations"
          ],
          "properties": {
            "horizon_weeks": {
              "type": "integer",
              "minimum": 1
            },
            "observations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "trend",
                  "interpretation"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "trend": {
                    "type": "string",
                    "enum": [
                      "improving",
                      "stable",
                      "declining"
                    ]
                  },
                  "interpretation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "scope",
            "urgency",
            "rationale",
            "suggested_considerations",
            "explicitly_not"
          ],
          "properties": {
            "type": {
              "const": "advisory",
              "type": "string"
            },
            "scope": {
              "const": "Season-Planner",
              "type": "string"
            },
            "urgency": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "suggested_considerations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "explicitly_not": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "string",
                "enum": [
                  "direct_phase_change",
                  "weekly_intervention"
                ]
              }
            }
          }
        },
        "narrative_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "overview_current_status",
            "detailed_analysis_last_week",
            "trend_analysis_within_phase",
            "trend_analysis_season",
            "interpretation_recommendation"
          ],
          "properties": {
            "overview_current_status": {
              "type": "string",
              "minLength": 1
            },
            "detailed_analysis_last_week": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_within_phase": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_season": {
              "type": "string",
              "minLength": 1
            },
            "interpretation_recommendation": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "kpi_status_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "confidence",
        "evidence_window",
        "delta_vs_baseline"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weeks"
          ],
          "properties": {
            "weeks": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "delta_vs_baseline": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "DES_ANALYSIS_REPORT",
          "type": "string"
        },
        "schema_id": {
          "const": "DESAnalysisInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.1",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Performance-Analyst",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent",
        "iso_week"
      ],
      "type": "object"
    },
    "data": {
      "$ref": "#/$defs/des_analysis_report_data"
    }
  }
}
