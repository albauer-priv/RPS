{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "macro_overview.schema.json",
  "title": "MacroOverview",
  "allOf": [
    {
      "$ref": "artefact_envelope.schema.json"
    },
    {
      "properties": {
        "meta": {
          "properties": {
            "artifact_type": {"const": "MACRO_OVERVIEW"},
            "schema_id": {"const": "MacroOverviewInterface"},
            "schema_version": {"const": "1.0"},
            "authority": {"const": "Binding"},
            "owner_agent": {"const": "Macro-Planner"}
          },
          "required": [
            "artifact_type",
            "schema_id",
            "schema_version",
            "authority",
            "owner_agent",
            "iso_week_range"
          ]
        },
        "data": {
          "$ref": "#/$defs/macro_overview_data"
        }
      }
    }
  ],
  "$defs": {
    "macro_overview_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "body_metadata",
        "macro_intent_principles",
        "phases",
        "global_constraints",
        "season_load_envelope",
        "assumptions_unknowns",
        "phase_transitions_guardrails",
        "principles_scientific_foundation",
        "explicit_forbidden_content",
        "self_check"
      ],
      "properties": {
        "body_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "planning_horizon_weeks",
            "season_brief_ref",
            "kpi_profile_ref",
            "reference_mass_window_kg",
            "energetic_preload_references_kj_per_kg"
          ],
          "properties": {
            "planning_horizon_weeks": {
              "type": "integer",
              "minimum": 8,
              "maximum": 32
            },
            "season_brief_ref": {
              "type": "string",
              "minLength": 1
            },
            "kpi_profile_ref": {
              "type": "string",
              "minLength": 1
            },
            "athlete_profile_ref": {
              "type": "string"
            },
            "reference_mass_window_kg": {
              "$ref": "number_range.schema.json"
            },
            "energetic_preload_references_kj_per_kg": {
              "type": "object",
              "additionalProperties": false,
              "required": ["single_day", "back_to_back"],
              "properties": {
                "single_day": {
                  "$ref": "number_range.schema.json"
                },
                "back_to_back": {
                  "$ref": "number_range.schema.json"
                }
              }
            }
          }
        },
        "macro_intent_principles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "season_objective",
            "success_definition",
            "non_negotiable_principles",
            "kJ_corridor_design_notes"
          ],
          "properties": {
            "season_objective": {
              "type": "string",
              "minLength": 1
            },
            "success_definition": {
              "type": "string",
              "enum": ["event-focused", "durability-focused", "mixed"]
            },
            "non_negotiable_principles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "kJ_corridor_design_notes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/phase"
          }
        },
        "global_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "availability_assumptions",
            "risk_constraints"
          ],
          "properties": {
            "availability_assumptions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "planned_event_windows": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "risk_constraints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "season_load_envelope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "expected_average_weekly_kj_range",
            "expected_high_load_weeks_count",
            "expected_deload_or_low_load_weeks_count"
          ],
          "properties": {
            "expected_average_weekly_kj_range": {
              "$ref": "number_range.schema.json"
            },
            "expected_high_load_weeks_count": {
              "type": "integer",
              "minimum": 0
            },
            "expected_deload_or_low_load_weeks_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "assumptions_unknowns": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "assumptions",
            "uncertainties",
            "revisit_items"
          ],
          "properties": {
            "assumptions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "uncertainties": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "revisit_items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phase_transitions_guardrails": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "expected_progression",
            "conservative_triggers",
            "absolute_no_go_rules"
          ],
          "properties": {
            "expected_progression": {
              "type": "string",
              "minLength": 1
            },
            "conservative_triggers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "absolute_no_go_rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "principles_scientific_foundation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "principle_applications",
            "scientific_foundation"
          ],
          "properties": {
            "principle_applications": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["principle", "influence"],
                "properties": {
                  "principle": {
                    "type": "string",
                    "minLength": 1
                  },
                  "influence": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "scientific_foundation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "publications",
                "plan_alignment_check",
                "rationale"
              ],
              "properties": {
                "publications": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["authors", "year", "title", "link"],
                    "properties": {
                      "authors": {
                        "type": "string",
                        "minLength": 1
                      },
                      "year": {
                        "type": "integer",
                        "minimum": 1800,
                        "maximum": 2100
                      },
                      "title": {
                        "type": "string",
                        "minLength": 1
                      },
                      "link": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                },
                "plan_alignment_check": {
                  "type": "string",
                  "minLength": 1
                },
                "rationale": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "explicit_forbidden_content": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "block definitions (4-week plans)",
              "weekly schedules",
              "day-by-day structure",
              "workouts or interval prescriptions",
              "numeric progression rules",
              "daily or session-level kJ/TSS targets"
            ]
          }
        },
        "self_check": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "planning_horizon_is_at_least_8_weeks",
            "every_phase_defines_weekly_kj_corridor",
            "every_phase_includes_kj_per_kg_guardrails_and_reference_mass",
            "every_phase_maps_to_cycle_and_deload_intent",
            "every_phase_includes_narrative_and_metabolic_focus",
            "every_phase_includes_evaluation_focus_and_exit_assumptions",
            "season_load_envelope_and_assumptions_documented",
            "principles_and_scientific_foundation_documented",
            "allowed_forbidden_domains_listed",
            "no_meso_or_micro_planning_content",
            "header_includes_implements_iso_week_range_trace"
          ],
          "properties": {
            "planning_horizon_is_at_least_8_weeks": {"const": true},
            "every_phase_defines_weekly_kj_corridor": {"const": true},
            "every_phase_includes_kj_per_kg_guardrails_and_reference_mass": {"const": true},
            "every_phase_maps_to_cycle_and_deload_intent": {"const": true},
            "every_phase_includes_narrative_and_metabolic_focus": {"const": true},
            "every_phase_includes_evaluation_focus_and_exit_assumptions": {"const": true},
            "season_load_envelope_and_assumptions_documented": {"const": true},
            "principles_and_scientific_foundation_documented": {"const": true},
            "allowed_forbidden_domains_listed": {"const": true},
            "no_meso_or_micro_planning_content": {"const": true},
            "header_includes_implements_iso_week_range_trace": {"const": true}
          }
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "name",
        "date_range",
        "iso_week_range",
        "cycle",
        "deload",
        "reference_mass_window_kg",
        "narrative",
        "overview",
        "weekly_load_corridor",
        "allowed_forbidden_semantics",
        "structural_emphasis",
        "events_constraints"
      ],
      "properties": {
        "phase_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "date_range": {
          "$ref": "date_range.schema.json"
        },
        "iso_week_range": {
          "$ref": "iso_week_range.schema.json"
        },
        "cycle": {
          "type": "string",
          "enum": ["Base", "Build", "Peak", "Transition"]
        },
        "deload": {
          "type": "boolean"
        },
        "deload_rationale": {
          "type": "string"
        },
        "reference_mass_window_kg": {
          "$ref": "number_range.schema.json"
        },
        "narrative": {
          "type": "string",
          "minLength": 1
        },
        "overview": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "core_focus_and_characteristics",
            "phase_goals",
            "metabolic_focus",
            "expected_adaptations",
            "evaluation_focus",
            "phase_exit_assumptions",
            "typical_duration_intensity_pattern",
            "non_negotiables"
          ],
          "properties": {
            "core_focus_and_characteristics": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "phase_goals": {
              "type": "object",
              "additionalProperties": false,
              "required": ["primary"],
              "properties": {
                "primary": {
                  "type": "string",
                  "minLength": 1
                },
                "secondary": {
                  "type": "string"
                }
              }
            },
            "metabolic_focus": {
              "type": "string",
              "minLength": 1
            },
            "expected_adaptations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "evaluation_focus": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "phase_exit_assumptions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "typical_duration_intensity_pattern": {
              "type": "string",
              "minLength": 1
            },
            "non_negotiables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "weekly_load_corridor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weekly_kj"],
          "properties": {
            "weekly_kj": {
              "$ref": "load_band_kj_per_kg.schema.json"
            },
            "weekly_tss": {
              "$ref": "load_band.schema.json"
            }
          }
        },
        "allowed_forbidden_semantics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_intensity_domains", "allowed_load_modalities"],
          "properties": {
            "allowed_intensity_domains": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
            },
            "allowed_load_modalities": {
              "type": "array",
              "items": {"$ref": "agenda_enum.schema.json#/$defs/load_modality"}
            },
            "forbidden_intensity_domains": {
              "type": "array",
              "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
            }
          }
        },
        "structural_emphasis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["typical_focus", "not_emphasized"],
          "properties": {
            "typical_focus": {
              "type": "string",
              "minLength": 1
            },
            "not_emphasized": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "events_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["window", "type", "constraint"],
            "properties": {
              "window": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["A", "B", "C"]
              },
              "constraint": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "deload": {"const": true}
            }
          },
          "then": {
            "required": ["deload_rationale"]
          }
        },
        {
          "if": {
            "properties": {
              "deload": {"const": false}
            }
          },
          "then": {
            "not": {
              "required": ["deload_rationale"]
            }
          }
        }
      ]
    }
  }
}
