{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workouts_plan.schema.json",
  "title": "WorkoutsPlan",
  "allOf": [
    {
      "$ref": "artefact_envelope.schema.json"
    },
    {
      "properties": {
        "meta": {
          "properties": {
            "artifact_type": {"const": "WORKOUTS_PLAN"},
            "schema_id": {"const": "WorkoutsPlanInterface"},
            "schema_version": {"const": "1.2"},
            "authority": {"const": "Binding"},
            "owner_agent": {"const": "Micro-Planner"}
          },
          "required": [
            "artifact_type",
            "schema_id",
            "schema_version",
            "authority",
            "owner_agent",
            "iso_week"
          ]
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["week_summary", "agenda", "workouts"],
          "properties": {
            "week_summary": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "week_objective",
                "weekly_load_corridor_kj",
                "planned_weekly_load_kj"
              ],
              "properties": {
                "week_objective": {
                  "type": "string",
                  "minLength": 1
                },
                "weekly_load_corridor_kj": {
                  "$ref": "load_band.schema.json"
                },
                "planned_weekly_load_kj": {
                  "type": "number",
                  "minimum": 0
                },
                "cross_check_tss": {
                  "type": "number",
                  "minimum": 0
                },
                "notes": {
                  "type": "string"
                }
              }
            },
            "agenda": {
              "type": "array",
              "minItems": 7,
              "maxItems": 7,
              "items": {"$ref": "#/$defs/agenda_day"},
              "allOf": [
                {
                  "contains": {
                    "properties": {"day": {"const": "Mon"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Tue"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Wed"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Thu"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Fri"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Sat"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                },
                {
                  "contains": {
                    "properties": {"day": {"const": "Sun"}},
                    "required": ["day"]
                  },
                  "minContains": 1,
                  "maxContains": 1
                }
              ]
            },
            "workouts": {
              "type": "array",
              "items": {"$ref": "#/$defs/workout"}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "agenda_day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "day",
        "date",
        "day_role",
        "planned_duration",
        "planned_kj",
        "workout_id"
      ],
      "properties": {
        "day": {
          "type": "string",
          "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "day_role": {
          "$ref": "agenda_enum.schema.json#/$defs/day_role"
        },
        "planned_duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "planned_kj": {
          "type": "number",
          "minimum": 0
        },
        "planned_tss": {
          "type": "number",
          "minimum": 0
        },
        "workout_id": {
          "type": ["string", "null"]
        }
      }
    },
    "workout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workout_id",
        "title",
        "date",
        "start",
        "duration",
        "workout_text"
      ],
      "properties": {
        "workout_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
        },
        "workout_text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
