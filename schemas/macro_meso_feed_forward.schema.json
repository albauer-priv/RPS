{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "macro_meso_feed_forward.schema.json",
  "title": "MacroMesoFeedForward",
  "type": "object",
  "$defs": {
    "macro_meso_feed_forward_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_context",
        "decision_summary",
        "explicit_non_actions",
        "block_adjustment"
      ],
      "properties": {
        "source_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "season_plan_ref",
            "des_analysis_report_ref",
            "affected_block_id"
          ],
          "properties": {
            "season_plan_ref": {
              "type": "string",
              "minLength": 1
            },
            "des_analysis_report_ref": {
              "type": "string",
              "minLength": 1
            },
            "affected_block_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "decision_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conclusion",
            "rationale"
          ],
          "properties": {
            "conclusion": {
              "type": "string",
              "enum": [
                "no_change",
                "adjust_block",
                "reweight_macro"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "block_adjustment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applies_to_weeks",
            "adjustments"
          ],
          "properties": {
            "applies_to_weeks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "iso_week.schema.json"
              }
            },
            "adjustments": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kj_corridor",
                "quality_density"
              ],
              "properties": {
                "kj_corridor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "direction",
                    "percent"
                  ],
                  "properties": {
                    "direction": {
                      "type": "string",
                      "enum": [
                        "increase",
                        "decrease"
                      ]
                    },
                    "percent": {
                      "type": "number",
                      "minimum": 0
                    }
                  }
                },
                "quality_density": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "action",
                    "details"
                  ],
                  "properties": {
                    "action": {
                      "type": "string",
                      "enum": [
                        "allow",
                        "restrict"
                      ]
                    },
                    "details": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        },
        "explicit_non_actions": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "No weekly workout changes",
              "No micro-level intervention",
              "No KPI threshold enforcement"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "MACRO_MESO_FEED_FORWARD",
          "type": "string"
        },
        "schema_id": {
          "const": "MacroMesoFeedForwardInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Macro-Planner",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent",
        "iso_week"
      ],
      "type": "object"
    },
    "data": {
      "$ref": "#/$defs/macro_meso_feed_forward_data"
    }
  }
}
