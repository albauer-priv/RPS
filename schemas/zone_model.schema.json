{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zone_model.schema.json",
  "title": "ZoneModel",
  "type": "object",
  "$defs": {
    "percent_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "watt_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "zone_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_id",
        "name",
        "ftp_percent_range",
        "watt_range",
        "training_intent",
        "typical_if"
      ],
      "properties": {
        "zone_id": {
          "type": "string",
          "enum": [
            "Z1",
            "Z2",
            "Z3",
            "SS",
            "Z4",
            "Z5",
            "Z6",
            "Z7"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ftp_percent_range": {
          "$ref": "#/$defs/percent_range"
        },
        "watt_range": {
          "$ref": "#/$defs/watt_range"
        },
        "typical_if": {
          "type": [
            "number",
            "null"
          ]
        },
        "training_intent": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "zone_model_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_metadata",
        "zones",
        "examples",
        "versioning_usage"
      ],
      "properties": {
        "model_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "valid_from",
            "ftp_watts",
            "purpose",
            "filename"
          ],
          "properties": {
            "valid_from": {
              "type": "string",
              "format": "date"
            },
            "ftp_watts": {
              "type": "number",
              "minimum": 1
            },
            "purpose": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            }
          }
        },
        "zones": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/zone_entry"
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workout_name",
              "structure",
              "duration",
              "if_adj",
              "tss"
            ],
            "properties": {
              "workout_name": {
                "type": "string",
                "minLength": 1
              },
              "structure": {
                "type": "string",
                "minLength": 1
              },
              "duration": {
                "type": "string",
                "pattern": "^\\d{1,3}:\\d{2}(:\\d{2})?$"
              },
              "if_adj": {
                "type": "number"
              },
              "tss": {
                "type": "number"
              }
            }
          }
        },
        "versioning_usage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "ZONE_MODEL",
          "type": "string"
        },
        "schema_id": {
          "const": "ZoneModelInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Meso-Architect",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent"
      ],
      "type": "object"
    },
    "data": {
      "$ref": "#/$defs/zone_model_data"
    }
  }
}
