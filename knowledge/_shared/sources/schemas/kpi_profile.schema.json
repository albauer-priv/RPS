{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kpi_profile.schema.json",
  "title": "KPIProfile",
  "allOf": [
    {"$ref": "artefact_envelope.schema.json"},
    {
      "properties": {
        "meta": {
          "properties": {
            "artifact_type": {"const": "KPI_PROFILE"},
            "schema_id": {"const": "KPIProfileInterface"},
            "schema_version": {"const": "1.0"},
            "authority": {"const": "Binding"},
            "owner_agent": {"const": "Policy-Owner"}
          },
          "required": [
            "artifact_type",
            "schema_id",
            "schema_version",
            "authority",
            "owner_agent"
          ]
        },
        "data": {"$ref": "#/$defs/kpi_profile_data"}
      }
    }
  ],
  "$defs": {
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["green", "yellow", "red"],
      "properties": {
        "green": {"type": "string", "minLength": 1},
        "yellow": {"type": "string", "minLength": 1},
        "red": {"type": "string", "minLength": 1},
        "context": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "progression_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "warning", "stop"],
      "properties": {
        "allowed": {"type": "string", "minLength": 1},
        "warning": {"type": "string", "minLength": 1},
        "stop": {"type": "string", "minLength": 1}
      }
    },
    "number_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number", "minimum": 0},
        "max": {"type": "number", "minimum": 0}
      }
    },
    "number_range_nullable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": ["number", "null"], "minimum": 0},
        "max": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "kpi_profile_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_metadata",
        "energetic_load_targets",
        "durability",
        "multi_day_durability",
        "fueling_stability",
        "efficiency_drift",
        "intensity_control",
        "recovery_tolerability",
        "decision_rules",
        "traceability"
      ],
      "properties": {
        "profile_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile_id",
            "event_type",
            "distance_range",
            "athlete_class",
            "primary_objective"
          ],
          "properties": {
            "profile_id": {"type": "string", "minLength": 1},
            "event_type": {
              "type": "string",
              "enum": ["Brevet", "Gravel", "Ultra", "Stage", "Bikepacking"]
            },
            "distance_range": {"type": "string", "minLength": 1},
            "athlete_class": {"type": "string", "minLength": 1},
            "primary_objective": {
              "type": "string",
              "enum": ["Finish", "Performance", "Podium"]
            }
          }
        },
        "energetic_load_targets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weekly_load_kj", "progression_limits"],
          "properties": {
            "weekly_load_kj": {"$ref": "#/$defs/threshold"},
            "progression_limits": {
              "type": "object",
              "additionalProperties": false,
              "required": ["weekly_kj_increase", "long_ride_kj_increase"],
              "properties": {
                "weekly_kj_increase": {"$ref": "#/$defs/progression_limit"},
                "long_ride_kj_increase": {"$ref": "#/$defs/progression_limit"}
              }
            }
          }
        },
        "durability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["energetic_preload", "kpis"],
          "properties": {
            "energetic_preload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["single_ride_kj_per_kg", "back_to_back_kj_per_kg"],
              "properties": {
                "single_ride_kj_per_kg": {"$ref": "#/$defs/number_range_nullable"},
                "back_to_back_kj_per_kg": {"$ref": "#/$defs/number_range_nullable"},
                "single_ride_kj": {"type": "number", "minimum": 0},
                "back_to_back_kj": {"type": "number", "minimum": 0},
                "derived_from": {"type": "string", "minLength": 1},
                "mass_window_kj_per_kg": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "mass_window_kg",
                      "single_ride_kj_per_kg",
                      "back_to_back_kj_per_kg"
                    ],
                    "properties": {
                      "mass_window_kg": {"$ref": "#/$defs/number_range"},
                      "single_ride_kj_per_kg": {"$ref": "#/$defs/number_range"},
                      "back_to_back_kj_per_kg": {"$ref": "#/$defs/number_range"}
                    }
                  }
                }
              }
            },
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "durability_index",
                "sustained_power_drop_3h_vs_1h_percent",
                "back_to_back_ratio",
                "fir_5min_20min"
              ],
              "properties": {
                "durability_index": {"$ref": "#/$defs/threshold"},
                "sustained_power_drop_3h_vs_1h_percent": {"$ref": "#/$defs/threshold"},
                "back_to_back_ratio": {"$ref": "#/$defs/threshold"},
                "fir_5min_20min": {"$ref": "#/$defs/threshold"}
              }
            }
          }
        },
        "multi_day_durability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applies_to",
            "evaluation_window",
            "purpose",
            "kpis",
            "dominance_rule"
          ],
          "properties": {
            "applies_to": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "evaluation_window": {"type": "string", "minLength": 1},
            "purpose": {"type": "string", "minLength": 1},
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "bbr_trend_day_n_vs_day_n_minus_1",
                "if_stability_delta_day_to_day",
                "hr_drift_trend"
              ],
              "properties": {
                "bbr_trend_day_n_vs_day_n_minus_1": {"$ref": "#/$defs/threshold"},
                "if_stability_delta_day_to_day": {"$ref": "#/$defs/threshold"},
                "hr_drift_trend": {"$ref": "#/$defs/threshold"}
              }
            },
            "dominance_rule": {"type": "string", "minLength": 1}
          }
        },
        "fueling_stability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["validity_requirement", "purpose", "kpis", "interpretation_rule"],
          "properties": {
            "validity_requirement": {"type": "string", "minLength": 1},
            "purpose": {"type": "string", "minLength": 1},
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "if_decline_under_preload",
                "hr_drift_under_preload",
                "decoupling_under_preload"
              ],
              "properties": {
                "if_decline_under_preload": {"$ref": "#/$defs/threshold"},
                "hr_drift_under_preload": {"$ref": "#/$defs/threshold"},
                "decoupling_under_preload": {"$ref": "#/$defs/threshold"}
              }
            },
            "interpretation_rule": {"type": "string", "minLength": 1}
          }
        },
        "efficiency_drift": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kpis"],
          "properties": {
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pa_hr_z2_90min", "hr_drift_race_pace", "ef_trend"],
              "properties": {
                "pa_hr_z2_90min": {"$ref": "#/$defs/threshold"},
                "hr_drift_race_pace": {"$ref": "#/$defs/threshold"},
                "ef_trend": {"$ref": "#/$defs/threshold"}
              }
            }
          }
        },
        "intensity_control": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kpis"],
          "properties": {
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": ["vo2_tiz_per_week", "sst_tiz_per_week"],
              "properties": {
                "vo2_tiz_per_week": {"$ref": "#/$defs/threshold"},
                "sst_tiz_per_week": {"$ref": "#/$defs/threshold"}
              }
            }
          }
        },
        "recovery_tolerability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kpis"],
          "properties": {
            "kpis": {
              "type": "object",
              "additionalProperties": false,
              "required": ["tsb_sun", "subjective_fatigue"],
              "properties": {
                "tsb_sun": {"$ref": "#/$defs/threshold"},
                "subjective_fatigue": {"$ref": "#/$defs/threshold"}
              }
            }
          }
        },
        "decision_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["green", "yellow", "red"],
          "properties": {
            "green": {"type": "string", "minLength": 1},
            "yellow": {"type": "string", "minLength": 1},
            "red": {"type": "string", "minLength": 1}
          }
        },
        "traceability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requirements"],
          "properties": {
            "requirements": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
