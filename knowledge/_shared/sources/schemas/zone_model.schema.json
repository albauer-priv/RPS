{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zone_model.schema.json",
  "title": "ZoneModel",
  "allOf": [
    {
      "$ref": "artefact_envelope.schema.json"
    },
    {
      "properties": {
        "meta": {
          "properties": {
            "artifact_type": {"const": "ZONE_MODEL"},
            "schema_id": {"const": "ZoneModelInterface"},
            "schema_version": {"const": "1.0"},
            "authority": {"const": "Binding"},
            "owner_agent": {"const": "Meso-Architect"}
          },
          "required": [
            "artifact_type",
            "schema_id",
            "schema_version",
            "authority",
            "owner_agent"
          ]
        },
        "data": {
          "$ref": "#/$defs/zone_model_data"
        }
      }
    }
  ],
  "$defs": {
    "percent_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number", "minimum": 0},
        "max": {"type": "number", "minimum": 0}
      }
    },
    "watt_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "number", "minimum": 0},
        "max": {"type": "number", "minimum": 0}
      }
    },
    "zone_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_id",
        "name",
        "ftp_percent_range",
        "watt_range",
        "training_intent"
      ],
      "properties": {
        "zone_id": {
          "type": "string",
          "enum": ["Z1", "Z2", "Z3", "SS", "Z4", "Z5", "Z6", "Z7"]
        },
        "name": {"type": "string", "minLength": 1},
        "ftp_percent_range": {"$ref": "#/$defs/percent_range"},
        "watt_range": {"$ref": "#/$defs/watt_range"},
        "typical_if": {"type": ["number", "null"]},
        "training_intent": {"type": "string", "minLength": 1}
      }
    },
    "zone_model_data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_metadata", "zones"],
      "properties": {
        "model_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["valid_from", "ftp_watts"],
          "properties": {
            "valid_from": {"type": "string", "format": "date"},
            "ftp_watts": {"type": "number", "minimum": 1},
            "purpose": {"type": "string"},
            "filename": {"type": "string"}
          }
        },
        "zones": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/zone_entry"},
          "allOf": [
            {
              "contains": {"properties": {"zone_id": {"const": "Z1"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z2"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z3"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "SS"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z4"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z5"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z6"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {"properties": {"zone_id": {"const": "Z7"}}, "required": ["zone_id"]},
              "minContains": 1,
              "maxContains": 1
            }
          ]
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["workout_name", "structure", "duration"],
            "properties": {
              "workout_name": {"type": "string", "minLength": 1},
              "structure": {"type": "string", "minLength": 1},
              "duration": {"type": "string", "pattern": "^\\d{1,3}:\\d{2}(:\\d{2})?$"},
              "if_adj": {"type": "number"},
              "tss": {"type": "number"}
            }
          }
        },
        "versioning_usage": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
