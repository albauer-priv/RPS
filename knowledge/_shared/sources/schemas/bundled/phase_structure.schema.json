{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase_structure.schema.json",
  "title": "PhaseStructure",
  "type": "object",
  "$defs": {
    "weekday": {
      "type": "string",
      "enum": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ]
    },
    "weekly_band_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "week",
        "band"
      ],
      "properties": {
        "week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "band": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "load_band.schema.json",
          "title": "LoadBand",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "max",
            "notes"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "phase_structure_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_intent",
        "load_ranges",
        "execution_principles",
        "structural_building_blocks",
        "week_skeleton_logic",
        "adaptation_rules",
        "relationships",
        "self_check"
      ],
      "properties": {
        "upstream_intent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "block_type",
            "primary_objective",
            "block_status",
            "non_negotiables",
            "constraints",
            "key_risks_warnings"
          ],
          "properties": {
            "block_type": {
              "type": "string",
              "minLength": 1
            },
            "primary_objective": {
              "type": "string",
              "minLength": 1
            },
            "block_status": {
              "type": "string",
              "enum": [
                "Green",
                "Yellow",
                "Red"
              ]
            },
            "non_negotiables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "constraints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "key_risks_warnings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "load_ranges": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weekly_kj_bands",
            "source"
          ],
          "properties": {
            "weekly_kj_bands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "week",
                  "band"
                ],
                "properties": {
                  "week": {
                    "$schema": "https://json-schema.org/draft/2020-12/schema",
                    "$id": "iso_week.schema.json",
                    "title": "IsoWeek",
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}$"
                  },
                  "band": {
                    "$schema": "https://json-schema.org/draft/2020-12/schema",
                    "$id": "load_band.schema.json",
                    "title": "LoadBand",
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "min",
                      "max",
                      "notes"
                    ],
                    "properties": {
                      "min": {
                        "type": "number",
                        "minimum": 0
                      },
                      "max": {
                        "type": "number",
                        "minimum": 0
                      },
                      "notes": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "execution_principles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "load_intensity_handling",
            "recovery_protection",
            "consistency_over_optimization"
          ],
          "properties": {
            "load_intensity_handling": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "max_quality_days_per_week",
                "allowed_intensity_domains",
                "forbidden_intensity_domains",
                "load_modality_constraints",
                "quality_intent"
              ],
              "properties": {
                "max_quality_days_per_week": {
                  "type": "integer",
                  "minimum": 0
                },
                "quality_intent": {
                  "type": "string",
                  "enum": [
                    "Stabilization",
                    "Build",
                    "Overload"
                  ]
                },
                "allowed_intensity_domains": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "RECOVERY",
                      "ENDURANCE",
                      "ENDURANCE_LOW",
                      "ENDURANCE_HIGH",
                      "TEMPO",
                      "SWEET_SPOT",
                      "THRESHOLD",
                      "VO2MAX"
                    ]
                  }
                },
                "forbidden_intensity_domains": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "RECOVERY",
                      "ENDURANCE",
                      "ENDURANCE_LOW",
                      "ENDURANCE_HIGH",
                      "TEMPO",
                      "SWEET_SPOT",
                      "THRESHOLD",
                      "VO2MAX"
                    ]
                  }
                },
                "load_modality_constraints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "K3"
                    ]
                  }
                }
              }
            },
            "recovery_protection": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "mandatory_recovery_spacing_rules",
                "forbidden_sequences",
                "long_endurance_anchor_protection",
                "fixed_non_training_days"
              ],
              "properties": {
                "fixed_non_training_days": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "Mon",
                      "Tue",
                      "Wed",
                      "Thu",
                      "Fri",
                      "Sat",
                      "Sun"
                    ]
                  }
                },
                "mandatory_recovery_spacing_rules": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "forbidden_sequences": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "long_endurance_anchor_protection": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "consistency_over_optimization": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "statements"
              ],
              "properties": {
                "statements": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "structural_building_blocks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_day_roles",
            "allowed_intensity_domains",
            "allowed_load_modalities"
          ],
          "properties": {
            "allowed_day_roles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "REST",
                  "RECOVERY",
                  "ENDURANCE",
                  "QUALITY",
                  "OPTIONAL",
                  "FLEX",
                  "TRAVEL",
                  "EVENT",
                  "OFF_BIKE"
                ]
              }
            },
            "allowed_intensity_domains": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "NONE",
                  "RECOVERY",
                  "ENDURANCE",
                  "ENDURANCE_LOW",
                  "ENDURANCE_HIGH",
                  "TEMPO",
                  "SWEET_SPOT",
                  "THRESHOLD",
                  "VO2MAX"
                ]
              }
            },
            "allowed_load_modalities": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "NONE",
                  "K3"
                ]
              }
            }
          }
        },
        "week_skeleton_logic": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "week_roles",
            "mandatory_elements",
            "optional_elements",
            "forbidden_patterns"
          ],
          "properties": {
            "week_roles": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "week_roles",
                "allowed_role_set"
              ],
              "properties": {
                "week_roles": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "week",
                      "role"
                    ],
                    "properties": {
                      "week": {
                        "$schema": "https://json-schema.org/draft/2020-12/schema",
                        "$id": "iso_week.schema.json",
                        "title": "IsoWeek",
                        "type": "string",
                        "pattern": "^\\d{4}-\\d{2}$"
                      },
                      "role": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                },
                "allowed_role_set": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "mandatory_elements": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "recovery_opportunities_min",
                "endurance_anchor_required"
              ],
              "properties": {
                "recovery_opportunities_min": {
                  "type": "integer",
                  "minimum": 1
                },
                "endurance_anchor_required": {
                  "type": "boolean"
                }
              }
            },
            "optional_elements": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "quality_days",
                "optional_flex_days"
              ],
              "properties": {
                "quality_days": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "capped_by_upstream_limits",
                    "never_adjacent_unless_allowed"
                  ],
                  "properties": {
                    "capped_by_upstream_limits": {
                      "type": "boolean"
                    },
                    "never_adjacent_unless_allowed": {
                      "type": "boolean"
                    }
                  }
                },
                "optional_flex_days": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "removable_without_compensation"
                  ],
                  "properties": {
                    "removable_without_compensation": {
                      "type": "boolean"
                    }
                  }
                }
              }
            },
            "forbidden_patterns": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "adaptation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relationships": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "guides",
            "does_not_replace"
          ],
          "properties": {
            "guides": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "does_not_replace": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "self_check": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "block_status_respected",
            "block_range_covered",
            "week_roles_defined_for_block_range",
            "no_new_decision_introduced",
            "no_numeric_target_introduced",
            "no_kpi_gate_inferred"
          ],
          "properties": {
            "block_status_respected": {
              "const": true,
              "type": "boolean"
            },
            "block_range_covered": {
              "const": true,
              "type": "boolean"
            },
            "week_roles_defined_for_block_range": {
              "const": true,
              "type": "boolean"
            },
            "no_new_decision_introduced": {
              "const": true,
              "type": "boolean"
            },
            "no_numeric_target_introduced": {
              "const": true,
              "type": "boolean"
            },
            "no_kpi_gate_inferred": {
              "const": true,
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artefact_meta.schema.json",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Macro-Planner",
            "Meso-Architect",
            "Micro-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Macro",
            "Meso",
            "Micro",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week_range.schema.json",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "date_range.schema.json",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_intent",
        "load_ranges",
        "execution_principles",
        "structural_building_blocks",
        "week_skeleton_logic",
        "adaptation_rules",
        "relationships",
        "self_check"
      ],
      "properties": {
        "upstream_intent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "block_type",
            "primary_objective",
            "block_status",
            "non_negotiables",
            "constraints",
            "key_risks_warnings"
          ],
          "properties": {
            "block_type": {
              "type": "string",
              "minLength": 1
            },
            "primary_objective": {
              "type": "string",
              "minLength": 1
            },
            "block_status": {
              "type": "string",
              "enum": [
                "Green",
                "Yellow",
                "Red"
              ]
            },
            "non_negotiables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "constraints": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "key_risks_warnings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "load_ranges": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weekly_kj_bands",
            "source"
          ],
          "properties": {
            "weekly_kj_bands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "week",
                  "band"
                ],
                "properties": {
                  "week": {
                    "$schema": "https://json-schema.org/draft/2020-12/schema",
                    "$id": "iso_week.schema.json",
                    "title": "IsoWeek",
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}$"
                  },
                  "band": {
                    "$schema": "https://json-schema.org/draft/2020-12/schema",
                    "$id": "load_band.schema.json",
                    "title": "LoadBand",
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "min",
                      "max",
                      "notes"
                    ],
                    "properties": {
                      "min": {
                        "type": "number",
                        "minimum": 0
                      },
                      "max": {
                        "type": "number",
                        "minimum": 0
                      },
                      "notes": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "execution_principles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "load_intensity_handling",
            "recovery_protection",
            "consistency_over_optimization"
          ],
          "properties": {
            "load_intensity_handling": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "max_quality_days_per_week",
                "allowed_intensity_domains",
                "forbidden_intensity_domains",
                "load_modality_constraints",
                "quality_intent"
              ],
              "properties": {
                "max_quality_days_per_week": {
                  "type": "integer",
                  "minimum": 0
                },
                "quality_intent": {
                  "type": "string",
                  "enum": [
                    "Stabilization",
                    "Build",
                    "Overload"
                  ]
                },
                "allowed_intensity_domains": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "RECOVERY",
                      "ENDURANCE",
                      "ENDURANCE_LOW",
                      "ENDURANCE_HIGH",
                      "TEMPO",
                      "SWEET_SPOT",
                      "THRESHOLD",
                      "VO2MAX"
                    ]
                  }
                },
                "forbidden_intensity_domains": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "RECOVERY",
                      "ENDURANCE",
                      "ENDURANCE_LOW",
                      "ENDURANCE_HIGH",
                      "TEMPO",
                      "SWEET_SPOT",
                      "THRESHOLD",
                      "VO2MAX"
                    ]
                  }
                },
                "load_modality_constraints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "K3"
                    ]
                  }
                }
              }
            },
            "recovery_protection": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "mandatory_recovery_spacing_rules",
                "forbidden_sequences",
                "long_endurance_anchor_protection",
                "fixed_non_training_days"
              ],
              "properties": {
                "fixed_non_training_days": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "Mon",
                      "Tue",
                      "Wed",
                      "Thu",
                      "Fri",
                      "Sat",
                      "Sun"
                    ]
                  }
                },
                "mandatory_recovery_spacing_rules": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "forbidden_sequences": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "long_endurance_anchor_protection": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "consistency_over_optimization": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "statements"
              ],
              "properties": {
                "statements": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "structural_building_blocks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_day_roles",
            "allowed_intensity_domains",
            "allowed_load_modalities"
          ],
          "properties": {
            "allowed_day_roles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "REST",
                  "RECOVERY",
                  "ENDURANCE",
                  "QUALITY",
                  "OPTIONAL",
                  "FLEX",
                  "TRAVEL",
                  "EVENT",
                  "OFF_BIKE"
                ]
              }
            },
            "allowed_intensity_domains": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "NONE",
                  "RECOVERY",
                  "ENDURANCE",
                  "ENDURANCE_LOW",
                  "ENDURANCE_HIGH",
                  "TEMPO",
                  "SWEET_SPOT",
                  "THRESHOLD",
                  "VO2MAX"
                ]
              }
            },
            "allowed_load_modalities": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "NONE",
                  "K3"
                ]
              }
            }
          }
        },
        "week_skeleton_logic": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "week_roles",
            "mandatory_elements",
            "optional_elements",
            "forbidden_patterns"
          ],
          "properties": {
            "week_roles": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "week_roles",
                "allowed_role_set"
              ],
              "properties": {
                "week_roles": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "week",
                      "role"
                    ],
                    "properties": {
                      "week": {
                        "$schema": "https://json-schema.org/draft/2020-12/schema",
                        "$id": "iso_week.schema.json",
                        "title": "IsoWeek",
                        "type": "string",
                        "pattern": "^\\d{4}-\\d{2}$"
                      },
                      "role": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                },
                "allowed_role_set": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "mandatory_elements": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "recovery_opportunities_min",
                "endurance_anchor_required"
              ],
              "properties": {
                "recovery_opportunities_min": {
                  "type": "integer",
                  "minimum": 1
                },
                "endurance_anchor_required": {
                  "type": "boolean"
                }
              }
            },
            "optional_elements": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "quality_days",
                "optional_flex_days"
              ],
              "properties": {
                "quality_days": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "capped_by_upstream_limits",
                    "never_adjacent_unless_allowed"
                  ],
                  "properties": {
                    "capped_by_upstream_limits": {
                      "type": "boolean"
                    },
                    "never_adjacent_unless_allowed": {
                      "type": "boolean"
                    }
                  }
                },
                "optional_flex_days": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "removable_without_compensation"
                  ],
                  "properties": {
                    "removable_without_compensation": {
                      "type": "boolean"
                    }
                  }
                }
              }
            },
            "forbidden_patterns": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "adaptation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relationships": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "guides",
            "does_not_replace"
          ],
          "properties": {
            "guides": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "does_not_replace": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "self_check": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "block_status_respected",
            "block_range_covered",
            "week_roles_defined_for_block_range",
            "no_new_decision_introduced",
            "no_numeric_target_introduced",
            "no_kpi_gate_inferred"
          ],
          "properties": {
            "block_status_respected": {
              "const": true,
              "type": "boolean"
            },
            "block_range_covered": {
              "const": true,
              "type": "boolean"
            },
            "week_roles_defined_for_block_range": {
              "const": true,
              "type": "boolean"
            },
            "no_new_decision_introduced": {
              "const": true,
              "type": "boolean"
            },
            "no_numeric_target_introduced": {
              "const": true,
              "type": "boolean"
            },
            "no_kpi_gate_inferred": {
              "const": true,
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
