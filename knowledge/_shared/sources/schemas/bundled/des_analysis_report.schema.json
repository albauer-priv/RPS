{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "des_analysis_report.schema.json",
  "title": "DESAnalysisReport",
  "type": "object",
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red",
        "inconclusive"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "des_analysis_report_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_meta",
        "kpi_summary",
        "weekly_analysis",
        "trend_analysis",
        "recommendation",
        "narrative_report"
      ],
      "properties": {
        "summary_meta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "year",
            "iso_week",
            "run_id"
          ],
          "properties": {
            "year": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100
            },
            "iso_week": {
              "type": "integer",
              "minimum": 1,
              "maximum": 53
            },
            "run_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "kpi_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "durability",
            "fatigue_resistance",
            "fueling_stability"
          ],
          "properties": {
            "durability": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "fatigue_resistance": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "fueling_stability": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "weekly_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context",
            "signals",
            "interpretation"
          ],
          "properties": {
            "context": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "block_week",
                "block_focus"
              ],
              "properties": {
                "block_week": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4
                },
                "block_focus": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "observation",
                  "confidence"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "observation": {
                    "type": "string",
                    "minLength": 1
                  },
                  "confidence": {
                    "type": "string",
                    "enum": [
                      "high",
                      "medium",
                      "low"
                    ]
                  }
                }
              }
            },
            "interpretation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "summary"
              ],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "trend_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "horizon_weeks",
            "observations"
          ],
          "properties": {
            "horizon_weeks": {
              "type": "integer",
              "minimum": 1
            },
            "observations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "trend",
                  "interpretation"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "trend": {
                    "type": "string",
                    "enum": [
                      "improving",
                      "stable",
                      "declining"
                    ]
                  },
                  "interpretation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "scope",
            "urgency",
            "rationale",
            "suggested_considerations",
            "explicitly_not"
          ],
          "properties": {
            "type": {
              "const": "advisory",
              "type": "string"
            },
            "scope": {
              "const": "Macro-Planner",
              "type": "string"
            },
            "urgency": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "suggested_considerations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "explicitly_not": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "string",
                "enum": [
                  "direct_block_change",
                  "weekly_intervention"
                ]
              }
            }
          }
        },
        "narrative_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "overview_current_status",
            "detailed_analysis_last_week",
            "trend_analysis_within_block",
            "trend_analysis_macro",
            "interpretation_recommendation"
          ],
          "properties": {
            "overview_current_status": {
              "type": "string",
              "minLength": 1
            },
            "detailed_analysis_last_week": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_within_block": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_macro": {
              "type": "string",
              "minLength": 1
            },
            "interpretation_recommendation": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "kpi_status_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "confidence",
        "evidence_window",
        "delta_vs_baseline"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "green",
            "yellow",
            "red",
            "inconclusive"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weeks"
          ],
          "properties": {
            "weeks": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "delta_vs_baseline": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artefact_meta.schema.json",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Macro-Planner",
            "Meso-Architect",
            "Micro-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Macro",
            "Meso",
            "Micro",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week_range.schema.json",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "date_range.schema.json",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_meta",
        "kpi_summary",
        "weekly_analysis",
        "trend_analysis",
        "recommendation",
        "narrative_report"
      ],
      "properties": {
        "summary_meta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "year",
            "iso_week",
            "run_id"
          ],
          "properties": {
            "year": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100
            },
            "iso_week": {
              "type": "integer",
              "minimum": 1,
              "maximum": 53
            },
            "run_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "kpi_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "durability",
            "fatigue_resistance",
            "fueling_stability"
          ],
          "properties": {
            "durability": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "fatigue_resistance": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "fueling_stability": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "confidence",
                "evidence_window",
                "delta_vs_baseline"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "green",
                    "yellow",
                    "red",
                    "inconclusive"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ]
                },
                "evidence_window": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "weeks"
                  ],
                  "properties": {
                    "weeks": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                "delta_vs_baseline": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "weekly_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context",
            "signals",
            "interpretation"
          ],
          "properties": {
            "context": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "block_week",
                "block_focus"
              ],
              "properties": {
                "block_week": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4
                },
                "block_focus": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "observation",
                  "confidence"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "observation": {
                    "type": "string",
                    "minLength": 1
                  },
                  "confidence": {
                    "type": "string",
                    "enum": [
                      "high",
                      "medium",
                      "low"
                    ]
                  }
                }
              }
            },
            "interpretation": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "summary"
              ],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "trend_analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "horizon_weeks",
            "observations"
          ],
          "properties": {
            "horizon_weeks": {
              "type": "integer",
              "minimum": 1
            },
            "observations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "metric",
                  "trend",
                  "interpretation"
                ],
                "properties": {
                  "metric": {
                    "type": "string",
                    "minLength": 1
                  },
                  "trend": {
                    "type": "string",
                    "enum": [
                      "improving",
                      "stable",
                      "declining"
                    ]
                  },
                  "interpretation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "scope",
            "urgency",
            "rationale",
            "suggested_considerations",
            "explicitly_not"
          ],
          "properties": {
            "type": {
              "const": "advisory",
              "type": "string"
            },
            "scope": {
              "const": "Macro-Planner",
              "type": "string"
            },
            "urgency": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "suggested_considerations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "explicitly_not": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "string",
                "enum": [
                  "direct_block_change",
                  "weekly_intervention"
                ]
              }
            }
          }
        },
        "narrative_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "overview_current_status",
            "detailed_analysis_last_week",
            "trend_analysis_within_block",
            "trend_analysis_macro",
            "interpretation_recommendation"
          ],
          "properties": {
            "overview_current_status": {
              "type": "string",
              "minLength": 1
            },
            "detailed_analysis_last_week": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_within_block": {
              "type": "string",
              "minLength": 1
            },
            "trend_analysis_macro": {
              "type": "string",
              "minLength": 1
            },
            "interpretation_recommendation": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
