{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tabular_data.schema.json",
  "title": "TabularData",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "columns",
    "rows"
  ],
  "properties": {
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "label",
          "type",
          "unit"
        ],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "integer",
              "boolean",
              "duration",
              "date",
              "date-time"
            ]
          },
          "unit": {
            "type": "string"
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        }
      }
    }
  },
  "$defs": {
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "type",
        "unit"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "integer",
            "boolean",
            "duration",
            "date",
            "date-time"
          ]
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "cell": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    }
  }
}
