                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "self_check": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "block_status_respected",
                "four_week_range_covered",
                "week_roles_defined_for_all_weeks",
                "no_new_decision_introduced",
                "no_numeric_target_introduced",
                "no_kpi_gate_inferred"
              ],
              "properties": {
                "block_status_respected": {
                  "const": true
                },
                "four_week_range_covered": {
                  "const": true
                },
                "week_roles_defined_for_all_weeks": {
                  "const": true
                },
                "no_new_decision_introduced": {
                  "const": true
                },
                "no_numeric_target_introduced": {
                  "const": true
                },
                "no_kpi_gate_inferred": {
                  "const": true
                }
              }
            }
          }
        }
      }
