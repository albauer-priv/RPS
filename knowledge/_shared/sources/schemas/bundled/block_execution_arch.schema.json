                },
                "optional_elements": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "quality_days",
                    "optional_flex_days"
                  ],
                  "properties": {
                    "quality_days": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "capped_by_upstream_limits",
                        "never_adjacent_unless_allowed"
                      ],
                      "properties": {
                        "capped_by_upstream_limits": {
                          "type": "boolean"
                        },
                        "never_adjacent_unless_allowed": {
                          "type": "boolean"
                        }
                      }
                    },
                    "optional_flex_days": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
