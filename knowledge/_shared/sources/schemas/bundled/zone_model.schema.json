{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zone_model.schema.json",
  "title": "ZoneModel",
  "type": "object",
  "$defs": {
    "percent_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "watt_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "zone_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "zone_id",
        "name",
        "ftp_percent_range",
        "watt_range",
        "training_intent",
        "typical_if"
      ],
      "properties": {
        "zone_id": {
          "type": "string",
          "enum": [
            "Z1",
            "Z2",
            "Z3",
            "SS",
            "Z4",
            "Z5",
            "Z6",
            "Z7"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "ftp_percent_range": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "watt_range": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "typical_if": {
          "type": [
            "number",
            "null"
          ]
        },
        "training_intent": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "zone_model_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_metadata",
        "zones",
        "examples",
        "versioning_usage"
      ],
      "properties": {
        "model_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "valid_from",
            "ftp_watts",
            "purpose",
            "filename"
          ],
          "properties": {
            "valid_from": {
              "type": "string",
              "format": "date"
            },
            "ftp_watts": {
              "type": "number",
              "minimum": 1
            },
            "purpose": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            }
          }
        },
        "zones": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "zone_id",
              "name",
              "ftp_percent_range",
              "watt_range",
              "training_intent",
              "typical_if"
            ],
            "properties": {
              "zone_id": {
                "type": "string",
                "enum": [
                  "Z1",
                  "Z2",
                  "Z3",
                  "SS",
                  "Z4",
                  "Z5",
                  "Z6",
                  "Z7"
                ]
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "ftp_percent_range": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number",
                    "minimum": 0
                  },
                  "max": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              },
              "watt_range": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number",
                    "minimum": 0
                  },
                  "max": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              },
              "typical_if": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "training_intent": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workout_name",
              "structure",
              "duration",
              "if_adj",
              "tss"
            ],
            "properties": {
              "workout_name": {
                "type": "string",
                "minLength": 1
              },
              "structure": {
                "type": "string",
                "minLength": 1
              },
              "duration": {
                "type": "string",
                "pattern": "^\\d{1,3}:\\d{2}(:\\d{2})?$"
              },
              "if_adj": {
                "type": "number"
              },
              "tss": {
                "type": "number"
              }
            }
          }
        },
        "versioning_usage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artefact_meta.schema.json",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "Data-Pipeline",
            "Macro-Planner",
            "Meso-Architect",
            "Micro-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Macro",
            "Meso",
            "Micro",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week_range.schema.json",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "date_range.schema.json",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_metadata",
        "zones",
        "examples",
        "versioning_usage"
      ],
      "properties": {
        "model_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "valid_from",
            "ftp_watts",
            "purpose",
            "filename"
          ],
          "properties": {
            "valid_from": {
              "type": "string",
              "format": "date"
            },
            "ftp_watts": {
              "type": "number",
              "minimum": 1
            },
            "purpose": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            }
          }
        },
        "zones": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "zone_id",
              "name",
              "ftp_percent_range",
              "watt_range",
              "training_intent",
              "typical_if"
            ],
            "properties": {
              "zone_id": {
                "type": "string",
                "enum": [
                  "Z1",
                  "Z2",
                  "Z3",
                  "SS",
                  "Z4",
                  "Z5",
                  "Z6",
                  "Z7"
                ]
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "ftp_percent_range": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number",
                    "minimum": 0
                  },
                  "max": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              },
              "watt_range": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "min",
                  "max"
                ],
                "properties": {
                  "min": {
                    "type": "number",
                    "minimum": 0
                  },
                  "max": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              },
              "typical_if": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "training_intent": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workout_name",
              "structure",
              "duration",
              "if_adj",
              "tss"
            ],
            "properties": {
              "workout_name": {
                "type": "string",
                "minLength": 1
              },
              "structure": {
                "type": "string",
                "minLength": 1
              },
              "duration": {
                "type": "string",
                "pattern": "^\\d{1,3}:\\d{2}(:\\d{2})?$"
              },
              "if_adj": {
                "type": "number"
              },
              "tss": {
                "type": "number"
              }
            }
          }
        },
        "versioning_usage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
