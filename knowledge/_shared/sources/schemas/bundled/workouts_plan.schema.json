{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workouts_plan.schema.json",
  "title": "WorkoutsPlan",
  "type": "object",
  "$defs": {
    "agenda_day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "day",
        "date",
        "day_role",
        "planned_duration",
        "planned_kj",
        "workout_id"
      ],
      "properties": {
        "day": {
          "type": "string",
          "enum": [
            "Mon",
            "Tue",
            "Wed",
            "Thu",
            "Fri",
            "Sat",
            "Sun"
          ]
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "day_role": {
          "type": "string",
          "enum": [
            "REST",
            "RECOVERY",
            "ENDURANCE",
            "QUALITY",
            "OPTIONAL",
            "FLEX",
            "TRAVEL",
            "EVENT",
            "OFF_BIKE"
          ]
        },
        "planned_duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "planned_kj": {
          "type": "number",
          "minimum": 0
        },
        "workout_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "workout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workout_id",
        "title",
        "date",
        "start",
        "duration",
        "workout_text",
        "notes"
      ],
      "properties": {
        "workout_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
        },
        "workout_text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artefact_meta.schema.json",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Macro-Planner",
            "Meso-Architect",
            "Micro-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Macro",
            "Meso",
            "Micro",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week_range.schema.json",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "date_range.schema.json",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string"
        },
        "data_confidence": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "data_confidence.schema.json",
          "title": "DataConfidenceLevel",
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "week_summary",
        "agenda",
        "workouts"
      ],
      "properties": {
        "week_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "week_objective",
            "weekly_load_corridor_kj",
            "planned_weekly_load_kj",
            "notes"
          ],
          "properties": {
            "week_objective": {
              "type": "string",
              "minLength": 1
            },
            "weekly_load_corridor_kj": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "$id": "load_band.schema.json",
              "title": "LoadBand",
              "type": "object",
              "additionalProperties": false,
              "required": [
                "min",
                "max",
                "notes"
              ],
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0
                },
                "max": {
                  "type": "number",
                  "minimum": 0
                },
                "notes": {
                  "type": "string"
                }
              }
            },
            "planned_weekly_load_kj": {
              "type": "number",
              "minimum": 0
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "agenda": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "day",
              "date",
              "day_role",
              "planned_duration",
              "planned_kj",
              "workout_id"
            ],
            "properties": {
              "day": {
                "type": "string",
                "enum": [
                  "Mon",
                  "Tue",
                  "Wed",
                  "Thu",
                  "Fri",
                  "Sat",
                  "Sun"
                ]
              },
              "date": {
                "type": "string",
                "format": "date"
              },
              "day_role": {
                "type": "string",
                "enum": [
                  "REST",
                  "RECOVERY",
                  "ENDURANCE",
                  "QUALITY",
                  "OPTIONAL",
                  "FLEX",
                  "TRAVEL",
                  "EVENT",
                  "OFF_BIKE"
                ]
              },
              "planned_duration": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              },
              "planned_kj": {
                "type": "number",
                "minimum": 0
              },
              "workout_id": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "workouts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "workout_id",
              "title",
              "date",
              "start",
              "duration",
              "workout_text",
              "notes"
            ],
            "properties": {
              "workout_id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date"
              },
              "start": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}$"
              },
              "duration": {
                "type": "string",
                "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
              },
              "workout_text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
