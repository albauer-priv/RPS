              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
