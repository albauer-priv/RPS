{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "availability.schema.json",
  "title": "Availability",
  "type": "object",
  "$defs": {
    "weekday_enum": {
      "type": "string",
      "enum": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ]
    },
    "weekly_hours": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "typical",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0
        },
        "typical": {
          "type": "number",
          "minimum": 0
        },
        "max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "availability_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weekday",
        "hours_min",
        "hours_typical",
        "hours_max",
        "indoor_possible",
        "travel_risk",
        "locked"
      ],
      "properties": {
        "weekday": {
          "type": "string",
          "enum": [
            "Mon",
            "Tue",
            "Wed",
            "Thu",
            "Fri",
            "Sat",
            "Sun"
          ]
        },
        "hours_min": {
          "type": "number",
          "minimum": 0
        },
        "hours_typical": {
          "type": "number",
          "minimum": 0
        },
        "hours_max": {
          "type": "number",
          "minimum": 0
        },
        "indoor_possible": {
          "type": "boolean"
        },
        "travel_risk": {
          "type": "string",
          "enum": [
            "low",
            "med",
            "high"
          ]
        },
        "locked": {
          "type": "boolean"
        }
      }
    },
    "availability_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_ref",
        "availability_table",
        "weekly_hours",
        "fixed_rest_days",
        "notes"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "manual",
            "season_brief",
            "imported"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "availability_table": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "weekday",
              "hours_min",
              "hours_typical",
              "hours_max",
              "indoor_possible",
              "travel_risk",
              "locked"
            ],
            "properties": {
              "weekday": {
                "type": "string",
                "enum": [
                  "Mon",
                  "Tue",
                  "Wed",
                  "Thu",
                  "Fri",
                  "Sat",
                  "Sun"
                ]
              },
              "hours_min": {
                "type": "number",
                "minimum": 0
              },
              "hours_typical": {
                "type": "number",
                "minimum": 0
              },
              "hours_max": {
                "type": "number",
                "minimum": 0
              },
              "indoor_possible": {
                "type": "boolean"
              },
              "travel_risk": {
                "type": "string",
                "enum": [
                  "low",
                  "med",
                  "high"
                ]
              },
              "locked": {
                "type": "boolean"
              }
            }
          }
        },
        "weekly_hours": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "typical",
            "max"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "typical": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "fixed_rest_days": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri",
              "Sat",
              "Sun"
            ]
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artefact_meta.schema.json",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "data_confidence",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Season-Planner",
            "Phase-Architect",
            "Week-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Season",
            "Phase",
            "Week",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week.schema.json",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "iso_week_range.schema.json",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "date_range.schema.json",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "trace_reference.schema.json",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "data_confidence": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "data_confidence.schema.json",
          "title": "DataConfidenceLevel",
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_ref",
        "availability_table",
        "weekly_hours",
        "fixed_rest_days",
        "notes"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "manual",
            "season_brief",
            "imported"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "availability_table": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "weekday",
              "hours_min",
              "hours_typical",
              "hours_max",
              "indoor_possible",
              "travel_risk",
              "locked"
            ],
            "properties": {
              "weekday": {
                "type": "string",
                "enum": [
                  "Mon",
                  "Tue",
                  "Wed",
                  "Thu",
                  "Fri",
                  "Sat",
                  "Sun"
                ]
              },
              "hours_min": {
                "type": "number",
                "minimum": 0
              },
              "hours_typical": {
                "type": "number",
                "minimum": 0
              },
              "hours_max": {
                "type": "number",
                "minimum": 0
              },
              "indoor_possible": {
                "type": "boolean"
              },
              "travel_risk": {
                "type": "string",
                "enum": [
                  "low",
                  "med",
                  "high"
                ]
              },
              "locked": {
                "type": "boolean"
              }
            }
          }
        },
        "weekly_hours": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "typical",
            "max"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "typical": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "fixed_rest_days": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Mon",
              "Tue",
              "Wed",
              "Thu",
              "Fri",
              "Sat",
              "Sun"
            ]
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
