{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "number_range.schema.json",
  "title": "NumberRange",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "min",
    "max"
  ],
  "properties": {
    "min": {
      "type": "number",
