{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "current_week_status_snapshot.schema.json",
  "title": "CurrentWeekStatusSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_upstream",
        "trace_data",
        "trace_events",
        "data_confidence",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "const": "CURRENT_WEEK_STATUS_SNAPSHOT"
        },
        "schema_id": {
          "const": "CurrentWeekStatusSnapshotInterface"
        },
        "schema_version": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "authority": {
          "const": "Derived"
        },
        "owner_agent": {
          "const": "Policy-Owner"
        },
        "run_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "const": "Context"
        },
        "iso_week": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}$"
        },
        "temporal_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array"
        },
        "trace_data": {
          "type": "array"
        },
        "trace_events": {
          "type": "array"
        },
        "data_confidence": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_iso_week",
        "source_versions",
        "prompt_blocks"
      ],
      "properties": {
        "target_iso_week": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "source_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "prompt_blocks": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
