{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "season_phase_feed_forward.schema.json",
  "title": "SeasonPhaseFeedForward",
  "type": "object",
  "$defs": {
    "season_phase_feed_forward_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_context",
        "decision_summary",
        "explicit_non_actions",
        "phase_adjustment"
      ],
      "properties": {
        "source_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "season_plan_ref",
            "des_analysis_report_ref",
            "affected_phase_id"
          ],
          "properties": {
            "season_plan_ref": {
              "type": "string",
              "minLength": 1
            },
            "des_analysis_report_ref": {
              "type": "string",
              "minLength": 1
            },
            "affected_phase_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "decision_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conclusion",
            "rationale"
          ],
          "properties": {
            "conclusion": {
              "type": "string",
              "enum": [
                "no_change",
                "adjust_phase",
                "reweight_season"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phase_adjustment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applies_to_weeks",
            "adjustments"
          ],
          "properties": {
            "applies_to_weeks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "title": "IsoWeek",
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}$"
              }
            },
            "adjustments": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kj_corridor",
                "quality_density"
              ],
              "properties": {
                "kj_corridor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "direction",
                    "percent"
                  ],
                  "properties": {
                    "direction": {
                      "type": "string",
                      "enum": [
                        "increase",
                        "decrease"
                      ]
                    },
                    "percent": {
                      "type": "number",
                      "minimum": 0
                    }
                  }
                },
                "quality_density": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "action",
                    "details"
                  ],
                  "properties": {
                    "action": {
                      "type": "string",
                      "enum": [
                        "allow",
                        "restrict"
                      ]
                    },
                    "details": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        },
        "explicit_non_actions": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "No weekly workout changes",
              "No week-level intervention",
              "No KPI threshold enforcement"
            ]
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "data_confidence",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "User",
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Season-Planner",
            "Phase-Architect",
            "Week-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Season",
            "Phase",
            "Week",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "data_confidence": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "DataConfidenceLevel",
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_context",
        "decision_summary",
        "explicit_non_actions",
        "phase_adjustment"
      ],
      "properties": {
        "source_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "season_plan_ref",
            "des_analysis_report_ref",
            "affected_phase_id"
          ],
          "properties": {
            "season_plan_ref": {
              "type": "string",
              "minLength": 1
            },
            "des_analysis_report_ref": {
              "type": "string",
              "minLength": 1
            },
            "affected_phase_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "decision_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conclusion",
            "rationale"
          ],
          "properties": {
            "conclusion": {
              "type": "string",
              "enum": [
                "no_change",
                "adjust_phase",
                "reweight_season"
              ]
            },
            "rationale": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phase_adjustment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applies_to_weeks",
            "adjustments"
          ],
          "properties": {
            "applies_to_weeks": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "title": "IsoWeek",
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}$"
              }
            },
            "adjustments": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kj_corridor",
                "quality_density"
              ],
              "properties": {
                "kj_corridor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "direction",
                    "percent"
                  ],
                  "properties": {
                    "direction": {
                      "type": "string",
                      "enum": [
                        "increase",
                        "decrease"
                      ]
                    },
                    "percent": {
                      "type": "number",
                      "minimum": 0
                    }
                  }
                },
                "quality_density": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "action",
                    "details"
                  ],
                  "properties": {
                    "action": {
                      "type": "string",
                      "enum": [
                        "allow",
                        "restrict"
                      ]
                    },
                    "details": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        },
        "explicit_non_actions": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "No weekly workout changes",
              "No week-level intervention",
              "No KPI threshold enforcement"
            ]
          }
        }
      }
    }
  }
}
