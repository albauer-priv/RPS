                  "phase_length_weeks": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "phase_count_expected": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "max_shortened_phases": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "shortening_budget_weeks": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "phase_plan_summary": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "full_phases",
                      "shortened_phases"
                    ],
                    "properties": {
                      "full_phases": {
                        "type": "integer",
                        "minimum": 0
                      },
                      "shortened_phases": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "len",
                            "count"
                          ],
                          "properties": {
                            "len": {
