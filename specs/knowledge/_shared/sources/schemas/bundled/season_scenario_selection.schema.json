{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "season_scenario_selection.schema.json",
  "title": "SeasonScenarioSelection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "ArtefactMeta",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "version",
        "authority",
        "owner_agent",
        "run_id",
        "created_at",
        "trace_upstream",
        "scope",
        "iso_week",
        "iso_week_range",
        "temporal_scope",
        "trace_data",
        "trace_events",
        "data_confidence",
        "notes"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
        },
        "authority": {
          "type": "string",
          "enum": [
            "Binding",
            "Informational",
            "Derived",
            "Factual"
          ]
        },
        "owner_agent": {
          "type": "string",
          "enum": [
            "User",
            "Data-Pipeline",
            "Season-Scenario-Agent",
            "Season-Planner",
            "Phase-Architect",
            "Week-Planner",
            "Workout-Builder",
            "Performance-Analyst",
            "Policy-Owner"
          ]
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "enum": [
            "Shared",
            "Season",
            "Phase",
            "Week",
            "Context"
          ]
        },
        "iso_week": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "IsoWeek",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$"
        },
        "iso_week_range": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "IsoWeekRange",
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}(?:\\+\\d+)?$"
        },
        "temporal_scope": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "DateRange",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "trace_upstream": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_data": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_events": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "TraceReference",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact",
              "version",
              "run_id"
            ],
            "properties": {
              "artifact": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
              },
              "run_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "data_confidence": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "title": "DataConfidenceLevel",
          "type": "string",
          "enum": [
            "HIGH",
            "MEDIUM",
            "LOW",
            "UNKNOWN"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "season_scenarios_ref",
        "selected_scenario_id",
        "selection_source",
        "selection_rationale",
        "notes",
        "kpi_moving_time_rate_guidance_selection"
      ],
      "properties": {
        "season_scenarios_ref": {
          "type": "string",
          "minLength": 1
        },
        "selected_scenario_id": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ]
        },
        "selection_source": {
          "type": "string",
          "enum": [
            "user",
            "system"
          ]
        },
        "selection_rationale": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "kpi_moving_time_rate_guidance_selection": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "segment",
            "w_per_kg",
            "kj_per_kg_per_hour"
          ],
          "properties": {
            "segment": {
              "type": "string",
              "minLength": 1
            },
            "w_per_kg": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "min",
                "max"
              ],
              "properties": {
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                }
              }
            },
            "kj_per_kg_per_hour": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "min",
                "max"
              ],
              "properties": {
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
