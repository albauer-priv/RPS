{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trace_reference.schema.json",
  "title": "TraceReference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact",
    "version",
    "schema_version",
    "version_key",
    "run_id"
  ],
  "properties": {
    "artifact": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "version_key": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
