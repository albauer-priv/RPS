{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase_guardrails.schema.json",
  "title": "PhaseGuardrails",
  "type": "object",
  "$defs": {
    "inherited_scenario_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_scenario_id",
        "scenario_name",
        "selection_rationale",
        "load_posture",
        "recovery_margin",
        "fatigue_exposure",
        "specificity_density",
        "load_philosophy",
        "risk_profile",
        "event_alignment_notes",
        "risk_flags",
        "season_archetype",
        "allowed_intensity_domains",
        "forbidden_intensity_domains",
        "deload_cadence"
      ],
      "properties": {
        "selected_scenario_id": {"type": "string", "enum": ["A", "B", "C"]},
        "scenario_name": {"type": "string", "minLength": 1},
        "selection_rationale": {"type": "string"},
        "load_posture": {"type": "string", "minLength": 1},
        "recovery_margin": {"type": "string", "minLength": 1},
        "fatigue_exposure": {"type": "string", "minLength": 1},
        "specificity_density": {"type": "string", "minLength": 1},
        "load_philosophy": {"type": "string", "minLength": 1},
        "risk_profile": {"type": "string", "minLength": 1},
        "event_alignment_notes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "risk_flags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "season_archetype": {"type": "string", "minLength": 1},
        "allowed_intensity_domains": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
        },
        "forbidden_intensity_domains": {
          "type": "array",
          "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
        },
        "deload_cadence": {"type": "string", "minLength": 1}
      }
    },
    "phase_guardrails_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "body_metadata",
        "inherited_scenario_contract",
        "phase_summary",
        "load_guardrails",
        "allowed_forbidden_semantics",
        "events_constraints",
        "execution_non_negotiables",
        "escalation_change_control",
        "explicit_forbidden_content",
        "self_check"
      ],
      "properties": {
        "body_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "phase_id",
            "phase_taxonomy_version",
            "phase_type",
            "phase_intent",
            "build_subtype",
            "phase_status",
            "change_type",
            "derived_from",
            "upstream_inputs"
          ],
          "properties": {
            "phase_id": {
              "type": "string",
              "minLength": 1
            },
            "phase_taxonomy_version": {
              "const": "canonical_phase_taxonomy_v1",
              "type": "string"
            },
            "phase_type": {
              "type": "string",
              "enum": [
                "TRANSITION",
                "PREPARATION",
                "BASE",
                "BUILD",
                "PEAK",
                "TAPER",
                "RACE"
              ]
            },
            "phase_intent": {
              "type": "string",
              "enum": [
                "transition_recovery",
                "preparation_re_entry",
                "shortened_re_entry",
                "general_base",
                "aerobic_base",
                "strength_endurance_base",
                "sweet_spot_base",
                "vo2_build",
                "threshold_build",
                "sst_build",
                "durability_build",
                "specificity_build",
                "vlamax_lowering",
                "peak_sharpening",
                "taper_freshening",
                "race_execution"
              ]
            },
            "build_subtype": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "vo2_build",
                "threshold_build",
                "sst_build",
                "durability_build",
                "specificity_build",
                "vlamax_lowering",
                null
              ]
            },
            "phase_status": {
              "type": "string",
              "enum": [
                "Green",
                "Yellow",
                "Red"
              ]
            },
            "change_type": {
              "type": "string",
              "enum": [
                "NEW",
                "ADJUSTED",
                "NONE"
              ]
            },
            "derived_from": {
              "type": "string"
            },
            "upstream_inputs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "allOf": [
            {
              "if": {
                "required": [
                  "phase_type"
                ],
                "properties": {
                  "phase_type": {
                    "const": "BUILD"
                  }
                }
              },
              "then": {
                "required": [
                  "build_subtype"
                ],
                "properties": {
                  "build_subtype": {
                    "enum": [
                      "vo2_build",
                      "threshold_build",
                      "sst_build",
                      "durability_build",
                      "specificity_build",
                      "vlamax_lowering"
                    ]
                  }
                }
              },
              "else": {
                "required": [
                  "build_subtype"
                ],
                "properties": {
                  "build_subtype": {
                    "type": "null"
                  }
                }
              }
            }
          ]
        },
        "inherited_scenario_contract": {
          "$ref": "#/$defs/inherited_scenario_contract"
        },
        "phase_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primary_objective",
            "key_risks_warnings",
            "non_negotiables",
            "secondary_objectives"
          ],
          "properties": {
            "primary_objective": {
              "type": "string",
              "minLength": 1
            },
            "secondary_objectives": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "key_risks_warnings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "non_negotiables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "load_guardrails": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weekly_kj_bands",
            "confidence_assumptions"
          ],
          "properties": {
            "weekly_kj_bands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/weekly_band_entry"
              }
            },
            "confidence_assumptions": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kj_estimation_method",
                "confidence",
                "ftp_watts_used",
                "zone_model_version"
              ],
              "properties": {
                "ftp_watts_used": {
                  "type": "number",
                  "minimum": 0
                },
                "zone_model_version": {
                  "type": "string"
                },
                "kj_estimation_method": {
                  "type": "string",
                  "enum": [
                    "AvgPower-based",
                    "IF+r heuristic",
                    "Mixed"
                  ]
                },
                "confidence": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "kj"
                  ],
                  "properties": {
                    "kj": {
                      "type": "string",
                      "enum": [
                        "HIGH",
                        "MED",
                        "LOW"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "allowed_forbidden_semantics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_day_roles",
            "allowed_intensity_domains",
            "allowed_load_modalities",
            "quality_density",
            "forbidden_day_roles",
            "forbidden_intensity_domains",
            "forbidden_load_modalities"
          ],
          "properties": {
            "allowed_day_roles": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/day_role"
              }
            },
            "forbidden_day_roles": {
              "type": "array",
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/day_role"
              }
            },
            "allowed_intensity_domains": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/intensity_domain"
              }
            },
            "forbidden_intensity_domains": {
              "type": "array",
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/intensity_domain"
              }
            },
            "allowed_load_modalities": {
              "type": "array",
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/load_modality"
              }
            },
            "forbidden_load_modalities": {
              "type": "array",
              "items": {
                "$ref": "agenda_enum.schema.json#/$defs/load_modality"
              }
            },
            "quality_density": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "max_quality_days_per_week",
                "quality_intent",
                "forbidden_patterns"
              ],
              "properties": {
                "max_quality_days_per_week": {
                  "type": "integer",
                  "minimum": 0
                },
                "quality_intent": {
                  "type": "string",
                  "enum": [
                    "Stabilization",
                    "Build",
                    "Overload"
                  ]
                },
                "forbidden_patterns": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "events_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "events",
            "logistics_time_constraints"
          ],
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "date",
                  "week",
                  "type",
                  "constraint"
                ],
                "properties": {
                  "date": {
                    "type": "string",
                    "format": "date"
                  },
                  "week": {
                    "$ref": "iso_week.schema.json"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "A",
                      "B",
                      "C"
                    ]
                  },
                  "constraint": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "logistics_time_constraints": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "travel_days": {
                  "type": "string"
                },
                "work_constraints": {
                  "type": "string"
                },
                "weather_or_indoor_constraints": {
                  "type": "string"
                }
              },
              "required": [
                "travel_days",
                "work_constraints",
                "weather_or_indoor_constraints"
              ]
            }
          }
        },
        "execution_non_negotiables": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "recovery_protection_rules",
            "long_endurance_anchor_protection",
            "minimum_recovery_opportunities",
            "no_catch_up_rule"
          ],
          "properties": {
            "recovery_protection_rules": {
              "type": "string",
              "minLength": 1
            },
            "long_endurance_anchor_protection": {
              "type": "string",
              "minLength": 1
            },
            "minimum_recovery_opportunities": {
              "type": "string",
              "minLength": 1
            },
            "no_catch_up_rule": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "escalation_change_control": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "warning_signals",
            "required_response"
          ],
          "properties": {
            "warning_signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "required_response": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "week_planner_must",
                "week_planner_must_not",
                "phase_architect_decides"
              ],
              "properties": {
                "week_planner_must": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "week_planner_must_not": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "phase_architect_decides": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "explicit_forbidden_content": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "string",
            "enum": [
              "day-by-day plans",
              "workouts or interval prescriptions",
              "durations, zones (Z1-Z7), %FTP",
              "daily kJ targets",
              "numeric progression rules",
              "recommendations that effectively plan the week level"
            ]
          }
        },
        "self_check": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weekly_kj_bands_present",
            "max_quality_days_specified",
            "allowed_forbidden_enums_specified",
            "no_week_planning_content",
            "header_includes_implements_iso_week_range_trace"
          ],
          "properties": {
            "weekly_kj_bands_present": {
              "const": true,
              "type": "boolean"
            },
            "max_quality_days_specified": {
              "const": true,
              "type": "boolean"
            },
            "allowed_forbidden_enums_specified": {
              "const": true,
              "type": "boolean"
            },
            "no_week_planning_content": {
              "const": true,
              "type": "boolean"
            },
            "header_includes_implements_iso_week_range_trace": {
              "const": true,
              "type": "boolean"
            }
          }
        }
      }
    },
    "weekly_band_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "week",
        "band"
      ],
      "properties": {
        "week": {
          "$ref": "iso_week.schema.json"
        },
        "band": {
          "$ref": "load_band.schema.json"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "PHASE_GUARDRAILS",
          "type": "string"
        },
        "schema_id": {
          "const": "PhaseGuardrailsInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Phase-Artifact-Writer",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent",
        "iso_week_range"
      ],
      "type": "object"
    },
    "data": {
      "$ref": "#/$defs/phase_guardrails_data"
    }
  }
}
