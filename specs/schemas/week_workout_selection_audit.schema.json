{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "week_workout_selection_audit.schema.json",
  "title": "WeekWorkoutSelectionAudit",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "data"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type", "schema_id", "schema_version", "version", "authority", "owner_agent",
        "run_id", "created_at", "scope", "iso_week", "iso_week_range", "temporal_scope",
        "trace_upstream", "trace_data", "trace_events", "data_confidence", "notes"
      ],
      "properties": {
        "artifact_type": {"const": "WEEK_WORKOUT_SELECTION_AUDIT"},
        "schema_id": {"const": "WeekWorkoutSelectionAuditInterface"},
        "schema_version": {"type": "string"},
        "version": {"type": "string"},
        "authority": {"const": "Derived"},
        "owner_agent": {"const": "Week-Selection-Auditor"},
        "run_id": {"type": "string"},
        "created_at": {"type": "string", "format": "date-time"},
        "scope": {"const": "Week"},
        "iso_week": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
        "iso_week_range": {"type": "string", "pattern": "^\\d{4}-\\d{2}--\\d{4}-\\d{2}$"},
        "temporal_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": {"type": "string", "format": "date"},
            "to": {"type": "string", "format": "date"}
          }
        },
        "trace_upstream": {"type": "array"},
        "trace_data": {"type": "array"},
        "trace_events": {"type": "array"},
        "data_confidence": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_iso_week",
        "selector_version",
        "rules_version",
        "source_versions",
        "csv_filename",
        "rows"
      ],
      "properties": {
        "target_iso_week": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
        "selector_version": {"type": "string"},
        "rules_version": {"type": "string"},
        "source_versions": {"type": "object", "additionalProperties": {"type": "string"}},
        "csv_filename": {"type": "string", "minLength": 1},
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "row_id",
              "athlete_id",
              "iso_week",
              "day",
              "day_role",
              "selected",
              "protocol_id",
              "protocol_variant",
              "protocol_type",
              "intensity_domain",
              "load_modality",
              "stimulus_class",
              "monotony_group",
              "phase_type",
              "phase_intent",
              "week_role",
              "season_archetype",
              "review_bucket",
              "preview_domain_hint",
              "preview_modality_hint",
              "allowed_domains_snapshot",
              "allowed_modalities_snapshot",
              "previous_signature_match",
              "legal",
              "filtered_reason_codes",
              "base_priority",
              "bonus_codes",
              "penalty_codes",
              "score",
              "tie_break_key",
              "tie_break_position",
              "selection_reason",
              "warnings"
            ],
            "properties": {
              "row_id": {"type": "string"},
              "athlete_id": {"type": "string"},
              "iso_week": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
              "day": {"type": "string", "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]},
              "day_role": {"type": "string"},
              "selected": {"type": "boolean"},
              "protocol_id": {"type": "string"},
              "protocol_variant": {"type": "string"},
              "protocol_type": {"type": "string"},
              "intensity_domain": {"type": "string"},
              "load_modality": {"type": "string"},
              "stimulus_class": {"type": "string"},
              "monotony_group": {"type": "string"},
              "phase_type": {"type": "string"},
              "phase_intent": {"type": "string"},
              "week_role": {"type": "string"},
              "season_archetype": {"type": "string"},
              "review_bucket": {"type": "string", "enum": ["SOLL", "KANN", "NUR_WENN", "VERMEIDEN"]},
              "preview_domain_hint": {"type": "string"},
              "preview_modality_hint": {"type": "string"},
              "allowed_domains_snapshot": {"type": "array", "items": {"type": "string"}},
              "allowed_modalities_snapshot": {"type": "array", "items": {"type": "string"}},
              "previous_signature_match": {"type": "string"},
              "legal": {"type": "boolean"},
              "filtered_reason_codes": {"type": "array", "items": {"type": "string"}},
              "base_priority": {"type": "number"},
              "bonus_codes": {"type": "array", "items": {"type": "string"}},
              "penalty_codes": {"type": "array", "items": {"type": "string"}},
              "score": {"type": "number"},
              "tie_break_key": {"type": "string"},
              "tie_break_position": {"type": "integer", "minimum": 1},
              "selection_reason": {"type": "string"},
              "warnings": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  }
}
