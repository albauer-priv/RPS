{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artefact_meta.schema.json",
  "title": "ArtefactMeta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_id",
    "schema_version",
    "version",
    "authority",
    "owner_agent",
    "run_id",
    "created_at",
    "trace_upstream",
    "scope",
    "iso_week",
    "iso_week_range",
    "temporal_scope",
    "trace_data",
    "trace_events",
    "data_confidence",
    "notes"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "schema_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "authority": {
      "type": "string",
      "enum": [
        "Binding",
        "Informational",
        "Derived",
        "Factual"
      ]
    },
    "owner_agent": {
      "type": "string",
      "enum": [
        "User",
        "Data-Pipeline",
        "Season-Scenario-Agent",
        "Season-Planner",
        "Phase-Architect",
        "Week-Planner",
        "Workout-Builder",
        "Performance-Analyst",
        "Policy-Owner"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "string",
      "enum": [
        "Shared",
        "Season",
        "Phase",
        "Week",
        "Context"
      ]
    },
    "iso_week": {
      "$ref": "iso_week.schema.json"
    },
    "iso_week_range": {
      "$ref": "iso_week_range.schema.json"
    },
    "temporal_scope": {
      "$ref": "date_range.schema.json"
    },
    "trace_upstream": {
      "type": "array",
      "items": {
        "$ref": "trace_reference.schema.json"
      }
    },
    "trace_data": {
      "type": "array",
      "items": {
        "$ref": "trace_reference.schema.json"
      }
    },
    "trace_events": {
      "type": "array",
      "items": {
        "$ref": "trace_reference.schema.json"
      }
    },
    "data_confidence": {
      "$ref": "data_confidence.schema.json"
    },
    "notes": {
      "type": "string"
    }
  }
}
