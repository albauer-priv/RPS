{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "selected_scenario_contract.schema.json",
  "title": "SelectedScenarioContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_scenario_id",
    "scenario_name",
    "selection_source",
    "selection_rationale",
    "load_posture",
    "recovery_margin",
    "fatigue_exposure",
    "specificity_density",
    "load_philosophy",
    "risk_profile",
    "best_suited_if",
    "key_differences",
    "main_payoff",
    "main_cost",
    "constraint_summary",
    "event_alignment_notes",
    "risk_flags",
    "kpi_guardrail_notes",
    "decision_notes",
    "season_archetype",
    "allowed_intensity_domains",
    "forbidden_intensity_domains",
    "deload_cadence",
    "phase_length_weeks",
    "phase_count_expected",
    "full_phases",
    "shortened_phases",
    "max_shortened_phases",
    "shortening_budget_weeks"
  ],
  "properties": {
    "selected_scenario_id": {"type": "string", "enum": ["A", "B", "C"]},
    "scenario_name": {"type": "string", "minLength": 1},
    "selection_source": {"type": "string", "enum": ["user", "system"]},
    "selection_rationale": {"type": "string"},
    "load_posture": {"type": "string", "minLength": 1},
    "recovery_margin": {"type": "string", "minLength": 1},
    "fatigue_exposure": {"type": "string", "minLength": 1},
    "specificity_density": {"type": "string", "minLength": 1},
    "load_philosophy": {"type": "string", "minLength": 1},
    "risk_profile": {"type": "string", "minLength": 1},
    "best_suited_if": {"type": "string", "minLength": 1},
    "key_differences": {"type": "string", "minLength": 1},
    "main_payoff": {"type": "string", "minLength": 1},
    "main_cost": {"type": "string", "minLength": 1},
    "constraint_summary": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "event_alignment_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "risk_flags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "kpi_guardrail_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "decision_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "season_archetype": {"type": "string", "minLength": 1},
    "allowed_intensity_domains": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
    },
    "forbidden_intensity_domains": {
      "type": "array",
      "items": {"$ref": "agenda_enum.schema.json#/$defs/intensity_domain"}
    },
    "deload_cadence": {"type": "string", "minLength": 1},
    "phase_length_weeks": {"type": "integer", "minimum": 1},
    "phase_count_expected": {"type": "integer", "minimum": 1},
    "full_phases": {"type": "integer", "minimum": 0},
    "shortened_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["len", "count"],
        "properties": {
          "len": {"type": "integer", "minimum": 1},
          "count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "max_shortened_phases": {"type": "integer", "minimum": 0},
    "shortening_budget_weeks": {"type": "integer", "minimum": 0}
  }
}
