{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase_preview.schema.json",
  "title": "PhasePreview",
  "type": "object",
  "$defs": {
    "weekday": {
      "type": "string",
      "enum": [
        "Mon",
        "Tue",
        "Wed",
        "Thu",
        "Fri",
        "Sat",
        "Sun"
      ]
    },
    "agenda_day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "day_of_week",
        "day_role",
        "intensity_domain",
        "load_modality",
        "notes"
      ],
      "properties": {
        "day_of_week": {
          "$ref": "#/$defs/weekday"
        },
        "day_role": {
          "$ref": "agenda_enum.schema.json#/$defs/day_role"
        },
        "intensity_domain": {
          "$ref": "agenda_enum.schema.json#/$defs/intensity_domain"
        },
        "load_modality": {
          "$ref": "agenda_enum.schema.json#/$defs/load_modality"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "week_agenda": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "week",
        "days"
      ],
      "properties": {
        "week": {
          "$ref": "iso_week.schema.json"
        },
        "days": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/agenda_day"
          }
        }
      }
    },
    "phase_preview_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_intent_summary",
        "feel_overview",
        "weekly_agenda_preview",
        "week_to_week_narrative",
        "deviation_rules",
        "traceability"
      ],
      "properties": {
        "phase_intent_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "phase_type",
            "primary_objective",
            "non_negotiables",
            "key_risks_warnings"
          ],
          "properties": {
            "phase_type": {
              "type": "string",
              "minLength": 1
            },
            "primary_objective": {
              "type": "string",
              "minLength": 1
            },
            "non_negotiables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "key_risks_warnings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "feel_overview": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dominant_theme",
            "intensity_handling_conceptual",
            "recovery_protection_conceptual"
          ],
          "properties": {
            "dominant_theme": {
              "type": "string",
              "minLength": 1
            },
            "intensity_handling_conceptual": {
              "type": "string",
              "minLength": 1
            },
            "recovery_protection_conceptual": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "weekly_agenda_preview": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/week_agenda"
          }
        },
        "week_to_week_narrative": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "direction",
            "what_will_not_change",
            "what_is_flexible"
          ],
          "properties": {
            "direction": {
              "type": "string",
              "minLength": 1
            },
            "what_will_not_change": {
              "type": "string",
              "minLength": 1
            },
            "what_is_flexible": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "deviation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "traceability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "derived_from",
            "conflict_resolution"
          ],
          "properties": {
            "derived_from": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "conflict_resolution": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "PHASE_PREVIEW",
          "type": "string"
        },
        "schema_id": {
          "const": "PhasePreviewInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Phase-Architect",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent",
        "iso_week_range"
      ],
      "type": "object"
    },
    "data": {
      "$ref": "#/$defs/phase_preview_data"
    }
  }
}
