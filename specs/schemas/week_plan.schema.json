{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "week_plan.schema.json",
  "title": "WeekPlan",
  "type": "object",
  "$defs": {
    "agenda_day": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "day",
        "date",
        "day_role",
        "planned_duration",
        "planned_kj",
        "workout_id"
      ],
      "properties": {
        "day": {
          "type": "string",
          "enum": [
            "Mon",
            "Tue",
            "Wed",
            "Thu",
            "Fri",
            "Sat",
            "Sun"
          ]
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "day_role": {
          "$ref": "agenda_enum.schema.json#/$defs/day_role"
        },
        "planned_duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "planned_kj": {
          "type": "number",
          "minimum": 0
        },
        "workout_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "workout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workout_id",
        "title",
        "date",
        "start",
        "duration",
        "workout_text",
        "notes"
      ],
      "properties": {
        "workout_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "start": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}$"
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
        },
        "workout_text": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "data"
  ],
  "properties": {
    "meta": {
      "$ref": "artefact_meta.schema.json",
      "properties": {
        "artifact_type": {
          "const": "WEEK_PLAN",
          "type": "string"
        },
        "schema_id": {
          "const": "WeekPlanInterface",
          "type": "string"
        },
        "schema_version": {
          "const": "1.2",
          "type": "string"
        },
        "authority": {
          "const": "Binding",
          "type": "string"
        },
        "owner_agent": {
          "const": "Week-Artifact-Writer",
          "type": "string"
        }
      },
      "required": [
        "artifact_type",
        "schema_id",
        "schema_version",
        "authority",
        "owner_agent",
        "iso_week"
      ],
      "type": "object"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inherited_planning_posture",
        "week_summary",
        "agenda",
        "workouts"
      ],
      "properties": {
        "inherited_planning_posture": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "selected_scenario_id",
            "load_posture",
            "recovery_margin",
            "fatigue_exposure",
            "specificity_density",
            "season_archetype",
            "allowed_intensity_domains",
            "forbidden_intensity_domains",
            "risk_flags",
            "phase_intent",
            "phase_week_role"
          ],
          "properties": {
            "selected_scenario_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "load_posture": {
              "type": [
                "string",
                "null"
              ]
            },
            "recovery_margin": {
              "type": [
                "string",
                "null"
              ]
            },
            "fatigue_exposure": {
              "type": [
                "string",
                "null"
              ]
            },
            "specificity_density": {
              "type": [
                "string",
                "null"
              ]
            },
            "season_archetype": {
              "type": [
                "string",
                "null"
              ]
            },
            "allowed_intensity_domains": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "forbidden_intensity_domains": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "risk_flags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "phase_intent": {
              "type": [
                "string",
                "null"
              ]
            },
            "phase_week_role": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "week_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "week_objective",
            "weekly_load_corridor_kj",
            "planned_weekly_load_kj",
            "notes"
          ],
          "properties": {
            "week_objective": {
              "type": "string",
              "minLength": 1
            },
            "weekly_load_corridor_kj": {
              "$ref": "load_band.schema.json"
            },
            "planned_weekly_load_kj": {
              "type": "number",
              "minimum": 0
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "agenda": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/agenda_day"
          }
        },
        "workouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workout"
          }
        }
      }
    }
  }
}
